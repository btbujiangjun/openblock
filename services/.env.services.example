# OpenBlock services — environment template (v1.14)
#
# 1. Copy to repo root as `.env`  (compose loads from CWD by default)
# 2. Replace every "REPLACE_ME_*" with strong unique values:
#       openssl rand -hex 32        # generic 256-bit secret
#       openssl rand -hex 64        # JWT_SECRET (≥32 chars enforced)
#       python -c 'import cryptography.fernet as f; print(f.Fernet.generate_key().decode())'
#                                   # ENCRYPTION_KEY (Fernet 32-byte url-safe key)
# 3. Run:  docker compose -f services/docker-compose.yml up --build
#
# DO NOT commit the populated .env. .gitignore already excludes `.env`.

# ---------- Postgres ----------
POSTGRES_DB=openblock
POSTGRES_USER=openblock
POSTGRES_PASSWORD=REPLACE_ME_postgres_password_min32chars

# Port published to the host (inside compose network it's always 5432)
POSTGRES_PORT_PUBLISH=5432

# ---------- Redis ----------
REDIS_PASSWORD=REPLACE_ME_redis_password_min32chars
REDIS_PORT_PUBLISH=6379

# ---------- Cross-cutting secrets ----------
# Fernet key (use the python one-liner above to generate)
ENCRYPTION_KEY=REPLACE_ME_fernet_key_44chars_urlsafe_b64

# JWT signing secret (min 32 chars). Use HS256 by default; switch to RS256
# in services/security/jwt_tokens.py when rolling out asymmetric keys.
JWT_SECRET=REPLACE_ME_jwt_secret_min32chars
JWT_ISSUER=openblock
JWT_AUDIENCE=openblock-clients
JWT_ACCESS_TTL=3600           # seconds
JWT_REFRESH_TTL=2592000       # 30 days

# Payment callback HMAC secret (min 32 chars).
PAYMENT_SECRET_KEY=REPLACE_ME_payment_secret_min32chars

# ---------- Rate limit backend (memory | redis) ----------
RATE_LIMIT_BACKEND=redis

# ---------- Observability ----------
SENTRY_DSN=
LOG_LEVEL=INFO

# ---------- Service ports (host publish) ----------
USER_PORT=8001
GAME_PORT=8002
ANALYTICS_PORT=8003
MONITORING_PORT=8004
GATEWAY_PORT=8000
