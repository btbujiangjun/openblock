# 前端（Vite）：复制为 web/.env.local 或仓库根 .env 后由 Vite 加载
# API 根地址，勿带末尾斜杠（会话/统计/回放等均经此写入 SQLite）
VITE_API_BASE_URL=http://localhost:5000
# 默认 true：持久化走 Flask 的 SQLite（blockblast.db），需同时运行 npm run server
# 设为 false 时 Database.init() 会拒绝启动（无 IndexedDB 回退）
VITE_USE_SQLITE_DB=true
# 设为 true 时额外用「第二套」远端会话同步（PUT 结束会话会写 user_stats/scores，易与主流程重复；SQLite 主存储下通常保持 false）
VITE_SYNC_BACKEND=false
# 为 true 时 RL 面板默认勾选「PyTorch 后端」（仍需 Flask /api/rl 与 pip install torch）
# VITE_RL_PYTORCH=true

# 后端（shell 环境）
# BLOCKBLAST_DB_PATH=/var/lib/openblock/blockblast.db
# PORT=5000
# FLASK_DEBUG=0
# —— RL PyTorch API（需 pip install torch；与 python -m rl_pytorch.train 共用 checkpoint）
# RL_CHECKPOINT_SAVE=rl_checkpoints/bb_policy.pt
# RL_TRAINING_LOG=rl_checkpoints/training.jsonl
# RL_AUTOLOAD=1
# 仅当需覆盖路径时设置 RL_CHECKPOINT=...
# RL_DEVICE=auto
# 网络规模（须与 checkpoint 训练时一致；高维 φ 默认更宽更深）
# RL_WIDTH=384
# RL_POLICY_DEPTH=6
# RL_VALUE_DEPTH=5
# RL_SAVE_EVERY=500
# RL_VALUE_COEF=0.18
# RL_VALUE_HUBER_BETA=150
# RL_ADV_MIN_STD=1e-4
# 回报缩放（价值头更稳、看板 Lv 尖峰减弱）；与浏览器 /api/rl/train_episode 一致，设 1 关闭
# RL_RETURN_SCALE=0.025
# 熵系数从 RL_ENTROPY_COEF 线性降到 RL_ENTROPY_COEF_MIN（默认 12000 局）
# RL_ENTROPY_COEF=0.015
# RL_ENTROPY_COEF_MIN=0.004
# RL_ENTROPY_DECAY_EPISODES=12000
# Apple Silicon 上 auto 会选 MPS；可显式 RL_DEVICE=mps
# 算子不支持时：PYTORCH_ENABLE_MPS_FALLBACK=1
# RL_MPS_SYNC=1
