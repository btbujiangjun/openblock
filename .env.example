# 前端（Vite）：复制为 web/.env.local 或仓库根 .env 后由 Vite 加载
# API 根地址，勿带末尾斜杠
VITE_API_BASE_URL=http://localhost:5000
# 设为 true 时向 Flask 同步会话与行为事件（需先启动后端）
VITE_SYNC_BACKEND=false
# 为 true 时 RL 面板默认勾选「PyTorch 后端」（仍需 Flask /api/rl 与 pip install torch）
# VITE_RL_PYTORCH=true

# 后端（shell 环境）
# BLOCKBLAST_DB_PATH=/var/lib/openblock/blockblast.db
# PORT=5000
# FLASK_DEBUG=0
# —— RL PyTorch API（需 pip install torch；与 python -m rl_pytorch.train 共用 checkpoint）
# RL_CHECKPOINT_SAVE=rl_checkpoints/bb_policy.pt
# RL_TRAINING_LOG=rl_checkpoints/training.jsonl
# RL_AUTOLOAD=1
# 仅当需覆盖路径时设置 RL_CHECKPOINT=...
# RL_DEVICE=auto
# RL_SAVE_EVERY=500
# RL_VALUE_COEF=0.18
# RL_VALUE_HUBER_BETA=150
# RL_ADV_MIN_STD=1e-4
# Apple Silicon 上 auto 会选 MPS；可显式 RL_DEVICE=mps
# 算子不支持时：PYTORCH_ENABLE_MPS_FALLBACK=1
# RL_MPS_SYNC=1
