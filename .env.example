# =============================================================================
# 前后端统一入口：修改「后端根地址」只改下面一行（或改 VITE_API_BASE_URL，二选一）
# 复制为仓库根目录 `.env`；本地覆盖可复制 `.env.local`（会覆盖 `.env` 同名键）
# =============================================================================
# 浏览器访问的 API 根 URL，无尾斜杠。局域网调试示例：
#   OPENBLOCK_API_ORIGIN=http://192.168.1.100:5000
OPENBLOCK_API_ORIGIN=http://0.0.0.0:5000

# 兼容旧配置：若未设置 OPENBLOCK_API_ORIGIN，Vite 构建脚本仍会读此项
# VITE_API_BASE_URL=http://0.0.0.0:5000

# 前端（Vite 注入）：以下仍由 Vite 从 .env 读取（未在 OPENBLOCK_API_ORIGIN 中涵盖）
# 默认 true：持久化走 Flask 的 SQLite（blockblast.db），需同时运行 npm run server
VITE_USE_SQLITE_DB=true
# 设为 true 时额外用「第二套」远端会话同步（通常保持 false）
VITE_SYNC_BACKEND=false
# 为 true 时 RL 面板默认勾选「PyTorch 后端」
# VITE_RL_PYTORCH=true

# PyTorch / rl_pytorch（CPU 训练可选）
# 默认由 rl_pytorch.torch_env 设 TORCH_NNPACK_ENABLED=0，消除 NNPACK 不支持硬件的告警；需 NNPACK 时设为 1
# TORCH_NNPACK_ENABLED=0
# RL_CPU_NUM_THREADS=8
# RL_CPU_INTEROP_THREADS=2
# RL_CPU_DATALOADER_WORKERS=2
# RL_SPAWN_DEVICE=cpu

# 后端（可选覆盖）
# 显式指定监听端口时优先于 URL 中的端口（一般不必设，与 OPENBLOCK_API_ORIGIN 一致即可）
# PORT=5000
# BLOCKBLAST_DB_PATH=/var/lib/openblock/blockblast.db
# FLASK_DEBUG=1
# —— RL PyTorch API（略，见原注释或 README）
# RL_CHECKPOINT_SAVE=rl_checkpoints/bb_policy.pt
# ...
