# =============================================================================
# 前后端统一入口：端口与功能开关集中管理。
# 复制为仓库根目录 `.env`；本地覆盖可复制 `.env.local`（会覆盖同名键）
# =============================================================================

# ---------- 端口与地址 ----------
# 前端 Vite 开发/预览端口（默认 3000）。也可用脚本固定端口：
#   npm run dev:3000   npm run dev:80
# 监听 80 等 <1024 需 root：npm run dev:sudo（脚本内已设 VITE_PORT=80）
VITE_PORT=3000
# 后端 Flask API 的 IP 和端口（前端自动拼接为 http://API_HOST:PORT）
API_HOST=127.0.0.1
PORT=5000

# ---------- 功能开关 ----------
# 持久化走 Flask 的 SQLite（openblock.db），需同时运行 npm run server
VITE_USE_SQLITE_DB=true
# 设为 true 时额外用远端会话同步（通常保持 false）
VITE_SYNC_BACKEND=false
# 为 true 时 RL 面板默认勾选「PyTorch 后端」
# VITE_RL_PYTORCH=true

# ---------- 后端可选覆盖 ----------
# OPENBLOCK_DB_PATH=openblock.db
# FLASK_DEBUG=1
# v1.14 起：/api/db-debug/* 默认关闭（生产安全）；本地调试时显式打开：
# OPENBLOCK_DB_DEBUG=1
# v1.14 起：CORS 默认仅放行本机 vite dev origins；生产部署设白名单（逗号分隔）：
# OPENBLOCK_ALLOWED_ORIGINS=https://play.example.com,https://m.example.com

# ---------- RL（Flask rl_backend / rl_pytorch，可选）----------
# RL_DEVICE=auto | cpu | mps | cuda（默认 auto）。Apple Silicon 上需 arm64 的 Python + 支持 MPS 的 PyTorch；
# 若为 Rosetta(x86) 或旧版 torch，mps 不可用时会回退 CPU。排查：GET /api/rl/status 看 mps_available / device_env。
# RL_DEVICE=mps
# 见 docs/RL_TRAINING_NUMERICAL_STABILITY.md
# RL_RETURNS_CLIP=512
# RL_VALUE_TARGET_CLIP=512
# RL_GAE_DELTA_CLIP=80
# RL_LOG_LOSS_CLIP=1e6
