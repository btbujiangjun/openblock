/**
 * Open Block 微信小程序 — 全局样式
 * 配色与 web/public/styles/main.css 保持一致
 */

page {
  --bg-primary: #090d1e;
  --bg-surface: #171b32;
  --bg-card: #202846;
  --text-primary: #f3f6ff;
  --text-secondary: #aeb7d0;
  --accent: #5ad487;
  --accent-glow: rgba(90, 212, 135, 0.36);
  --gold: #ffd166;
  --grid-line: rgba(255, 255, 255, 0.07);
  --grid-bg: #0c1022;

  background:
    radial-gradient(circle at 50% -10%, rgba(90, 212, 135, 0.10), transparent 32%),
    radial-gradient(circle at 12% 22%, rgba(125, 92, 255, 0.12), transparent 28%),
    linear-gradient(180deg, #101329 0%, var(--bg-primary) 42%, #070a18 100%);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  height: 100%;
  overflow: hidden;
}
