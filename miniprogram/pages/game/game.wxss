/* Open Block 微信小程序 — 游戏页面样式 */

.game-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  min-height: 100vh;
  padding: 0 18rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 50% 0%, rgba(90, 212, 135, 0.16), transparent 34%),
    radial-gradient(circle at 6% 26%, rgba(116, 164, 255, 0.16), transparent 25%),
    linear-gradient(180deg, #f7fbff 0%, #eef6f3 48%, #e8f0ff 100%);
}

/* --- 顶栏：与 web .score-theme-row 一致的三行栅格 + 胶囊条 --- */
.score-theme-row {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
  justify-content: center;
  gap: 0;
  width: 100%;
  max-width: 100%;
  margin: 12rpx 0 10rpx;
  box-sizing: border-box;
  background:
    linear-gradient(165deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.52) 46%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.90) 0%, rgba(239, 246, 255, 0.88) 100%);
  border: 1rpx solid rgba(83, 110, 140, 0.16);
  border-radius: 22rpx;
  box-shadow:
    0 2rpx 0 rgba(255, 255, 255, 0.80) inset,
    0 14rpx 34rpx rgba(52, 74, 108, 0.14);
  overflow: hidden;
  position: relative;
}

.score-theme-row .stat-box {
  flex: 1;
  min-width: 0;
  padding: 16rpx 10rpx 13rpx;
  position: relative;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  justify-items: center;
  align-items: center;
  row-gap: 4rpx;
}

.score-theme-row .stat-box + .stat-box::before {
  content: '';
  position: absolute;
  left: 0;
  top: 18%;
  bottom: 18%;
  width: 1rpx;
  background: rgba(57, 83, 112, 0.14);
  pointer-events: none;
}

.score-theme-row .stat-label {
  font-size: 20rpx;
  color: rgba(62, 76, 98, 0.72);
  letter-spacing: 0.06em;
  font-weight: 600;
  align-self: end;
}

.score-theme-row .stat-value {
  font-size: 40rpx;
  font-weight: 900;
  color: #233044;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  line-height: 1;
  text-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.72),
    0 0 18rpx rgba(90, 212, 135, 0.12);
  align-self: center;
}

.score-theme-row .stat-value--accent {
  color: #1c9b5f;
  text-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.22),
    0 0 20rpx rgba(90, 212, 135, 0.28);
}

.score-theme-row .stat-subline--spacer {
  visibility: hidden;
  pointer-events: none;
  min-height: calc(18rpx * 1.25 + 2rpx);
  margin-top: 2rpx;
  line-height: 1.25;
  font-size: 18rpx;
  width: 100%;
}

.score-theme-row .best-gap {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 2rpx;
  letter-spacing: 0.02em;
  align-self: start;
  width: 100%;
  text-align: center;
}

/* --- 顶栏右上角 fx 工具条：画质 / 视觉特效 / 音效 --- */
.fx-toolbar {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  z-index: 6;
}

.fx-toggle {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 34% 24%, rgba(255, 255, 255, 0.24), transparent 48%),
    rgba(12, 16, 34, 0.68);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow:
    0 2rpx 0 rgba(255, 255, 255, 0.10) inset,
    0 8rpx 16rpx rgba(0, 0, 0, 0.24);
  /* 关键：始终保持 100% 不透明，与 web 端 #quality-toggle 一致，
     避免"开/关"时透明度差异让按钮看起来不对齐。 */
  opacity: 1;
}

.fx-toggle--on {
  background:
    radial-gradient(circle at 34% 24%, rgba(255, 255, 255, 0.30), transparent 48%),
    rgba(32, 104, 68, 0.78);
  border-color: rgba(90, 212, 135, 0.38);
}

.fx-toggle--off {
  opacity: 0.72;
}

.fx-toggle--quality {
  /* 画质三档共享同一底色（与 web 端 #quality-toggle 强制 opacity:1 一致），
     图标即为视觉差异（🌈 / ⚖️ / 🔋），不靠透明度区分。 */
}

.fx-toggle-icon {
  font-size: 24rpx;
  line-height: 1;
}

/* --- 棋盘 --- */
.grid-wrapper {
  flex: 0 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0 10rpx;
}
.game-canvas {
  border-radius: 16rpx;
  box-shadow:
    0 16rpx 38rpx rgba(0, 0, 0, 0.24),
    0 0 0 1rpx rgba(255, 255, 255, 0.05);
}

.float-score {
  position: fixed;
  top: 260rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  background: rgba(23, 33, 54, 0.9);
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.02em;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow:
    0 2rpx 0 rgba(255, 255, 255, 0.12) inset,
    0 10rpx 28rpx rgba(0, 0, 0, 0.28),
    0 0 22rpx rgba(90, 212, 135, 0.18);
  z-index: 120;
}

.float-score--combo {
  color: #ffd166;
}

.float-score--bonus {
  color: #b794f4;
}

.float-score--new-best {
  color: #ffd166;
  font-size: 34rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.55), transparent 44%),
    linear-gradient(135deg, rgba(255, 209, 102, 0.95), rgba(255, 122, 217, 0.86), rgba(125, 211, 252, 0.9));
  color: #1a1028;
  border-color: rgba(255, 255, 255, 0.42);
  box-shadow:
    0 0 28rpx rgba(255, 209, 102, 0.58),
    0 12rpx 34rpx rgba(0, 0, 0, 0.34);
}

/* --- Dock 候选块 --- */
.dock {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: nowrap;
  gap: 34rpx;
  padding: 36rpx 18rpx 58rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: visible;
}
.dock-slot {
  flex: 0 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  background: transparent;
  border-radius: 0;
  box-sizing: border-box;
  transition: opacity 0.14s, transform 0.14s;
  overflow: visible;
}
.dock-slot--placed {
  opacity: 0;
  pointer-events: none;
}
.dock-slot--dragging {
  opacity: 0;
  transform: translateY(4rpx);
}
.dock-canvas {
  pointer-events: none;
}
.drag-preview-canvas {
  position: fixed;
  left: 0;
  top: 0;
  z-index: 92;
  pointer-events: none;
  filter: drop-shadow(0 14rpx 22rpx rgba(0, 0, 0, 0.28));
}

/* 落子失败时 preview 在原位"抖动 + 红光淡出"，与 web 端 #drag-ghost.is-rejected 同源
 * 让玩家立刻明白"刚才那个位置不行"，避免错以为游戏出 bug 了 */
@keyframes drag-preview-reject-shake {
  0%   { transform: translateX(0); opacity: 1; filter: drop-shadow(0 14rpx 22rpx rgba(0, 0, 0, 0.28)); }
  15%  { transform: translateX(-12rpx) rotate(-2deg); }
  30%  { transform: translateX(12rpx) rotate(2deg); }
  45%  { transform: translateX(-8rpx) rotate(-1.5deg); }
  60%  { transform: translateX(8rpx) rotate(1.5deg); }
  75%  { transform: translateX(-4rpx); opacity: 0.55; }
  100% { transform: translateX(0) scale(0.92); opacity: 0; filter: drop-shadow(0 0 0 transparent); }
}

.drag-preview-canvas--rejected {
  animation: drag-preview-reject-shake 240ms ease-out forwards;
  /* 失败抖动期间叠加红光，强化"这里放不下"的语义 */
  filter: drop-shadow(0 0 12rpx rgba(220, 38, 38, 0.65)) drop-shadow(0 14rpx 22rpx rgba(0, 0, 0, 0.28));
}
/* --- 游戏结束 --- */
.game-over-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.game-over-card {
  background: var(--bg-surface);
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  min-width: 400rpx;
}
.game-over-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
}
.game-over-score {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--gold);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  text-shadow:
    0 2rpx 0 rgba(120, 53, 15, 0.45),
    0 0 28rpx rgba(255, 209, 102, 0.34);
}
.game-over-clears {
  font-size: 32rpx;
  color: var(--text-secondary);
}
.game-over-btn {
  margin-top: 24rpx;
  padding: 20rpx 64rpx;
  background: var(--accent);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}
