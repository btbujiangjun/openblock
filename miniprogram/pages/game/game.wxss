/* Open Block 微信小程序 — 游戏页面样式 */

.game-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  padding: 0 16rpx;
  box-sizing: border-box;
  background-color: var(--bg-primary);
}

/* --- 顶栏：与 web .score-theme-row 一致的三行栅格 + 胶囊条 --- */
.score-theme-row {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
  justify-content: center;
  gap: 0;
  width: 100%;
  max-width: 100%;
  margin: 12rpx 0 8rpx;
  box-sizing: border-box;
  background:
    linear-gradient(165deg, rgba(255, 255, 255, 0.14) 0%, transparent 48%),
    linear-gradient(180deg, rgba(30, 30, 52, 0.95) 0%, rgba(22, 22, 40, 0.98) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
  overflow: hidden;
}

.score-theme-row .stat-box {
  flex: 1;
  min-width: 0;
  padding: 14rpx 10rpx 12rpx;
  position: relative;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  justify-items: center;
  align-items: center;
  row-gap: 4rpx;
}

.score-theme-row .stat-box + .stat-box::before {
  content: '';
  position: absolute;
  left: 0;
  top: 18%;
  bottom: 18%;
  width: 1rpx;
  background: rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

.score-theme-row .stat-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  letter-spacing: 0.06em;
  font-weight: 600;
  align-self: end;
}

.score-theme-row .stat-value {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  line-height: 1;
  text-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.22),
    0 0 18rpx rgba(90, 212, 135, 0.18);
  align-self: center;
}

.score-theme-row .stat-value--accent {
  color: #5ad487;
}

.score-theme-row .stat-subline--spacer {
  visibility: hidden;
  pointer-events: none;
  min-height: calc(18rpx * 1.25 + 2rpx);
  margin-top: 2rpx;
  line-height: 1.25;
  font-size: 18rpx;
  width: 100%;
}

.score-theme-row .best-gap {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 2rpx;
  letter-spacing: 0.02em;
  align-self: start;
  width: 100%;
  text-align: center;
}

/* --- 棋盘 --- */
.grid-wrapper {
  flex: 0 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0;
}
.game-canvas {
  border-radius: 12rpx;
}

.float-score {
  position: fixed;
  top: 260rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  background: rgba(23, 33, 54, 0.9);
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.02em;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow:
    0 2rpx 0 rgba(255, 255, 255, 0.12) inset,
    0 10rpx 28rpx rgba(0, 0, 0, 0.28),
    0 0 22rpx rgba(90, 212, 135, 0.18);
  z-index: 120;
}

.float-score--combo {
  color: #ffd166;
}

.float-score--bonus {
  color: #b794f4;
}

.float-score--new-best {
  color: #ffd166;
  font-size: 34rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.55), transparent 44%),
    linear-gradient(135deg, rgba(255, 209, 102, 0.95), rgba(255, 122, 217, 0.86), rgba(125, 211, 252, 0.9));
  color: #1a1028;
  border-color: rgba(255, 255, 255, 0.42);
  box-shadow:
    0 0 28rpx rgba(255, 209, 102, 0.58),
    0 12rpx 34rpx rgba(0, 0, 0, 0.34);
}

/* --- Dock 候选块 --- */
.dock {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx 0 48rpx;
  width: 100%;
}
.dock-slot {
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 12rpx;
  transition: opacity 0.2s, transform 0.15s;
}
.dock-slot--placed {
  opacity: 0.3;
}
.dock-slot--dragging {
  opacity: 0.5;
  transform: scale(0.9);
}
.dock-canvas {
  border-radius: 8rpx;
}
.dock-placed-mark {
  font-size: 40rpx;
  color: var(--text-secondary);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* --- 游戏结束 --- */
.game-over-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.game-over-card {
  background: var(--bg-surface);
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  min-width: 400rpx;
}
.game-over-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
}
.game-over-score {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--gold);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  text-shadow:
    0 2rpx 0 rgba(120, 53, 15, 0.45),
    0 0 28rpx rgba(255, 209, 102, 0.34);
}
.game-over-clears {
  font-size: 32rpx;
  color: var(--text-secondary);
}
.game-over-btn {
  margin-top: 24rpx;
  padding: 20rpx 64rpx;
  background: var(--accent);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}
