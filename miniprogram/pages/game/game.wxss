/* Open Block 微信小程序 — 游戏页面样式 */

.game-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  padding: 0 16rpx;
  box-sizing: border-box;
  background-color: var(--bg-primary);
}

/* --- 状态栏 --- */
.status-bar {
  display: flex;
  justify-content: space-around;
  width: 100%;
  padding: 24rpx 0 16rpx;
}
.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
}
.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
}

/* --- 棋盘 --- */
.grid-wrapper {
  flex: 0 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0;
}
.game-canvas {
  border-radius: 12rpx;
}

/* --- Dock 候选块 --- */
.dock {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx 0 48rpx;
  width: 100%;
}
.dock-slot {
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 12rpx;
  transition: opacity 0.2s, transform 0.15s;
}
.dock-slot--placed {
  opacity: 0.3;
}
.dock-slot--dragging {
  opacity: 0.5;
  transform: scale(0.9);
}
.dock-canvas {
  border-radius: 8rpx;
}
.dock-placed-mark {
  font-size: 40rpx;
  color: var(--text-secondary);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* --- 游戏结束 --- */
.game-over-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.game-over-card {
  background: var(--bg-surface);
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  min-width: 400rpx;
}
.game-over-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
}
.game-over-score {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--gold);
}
.game-over-clears {
  font-size: 32rpx;
  color: var(--text-secondary);
}
.game-over-btn {
  margin-top: 24rpx;
  padding: 20rpx 64rpx;
  background: var(--accent);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}
