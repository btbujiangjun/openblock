<!--
  Open Block 微信小程序 — 游戏页面
  Canvas 2D 绘制棋盘 + touch 事件驱动拖拽放置
  v1.60.46 顶栏对齐 web `.header header--title-only` + `.score-theme-row`：
    - 第 1 行：app-wordmark 字标（Open Block 文字 LOGO）
    - 第 2 行：能力（Lv.N + 称号）/ 得分 / 最佳 / 步数 / 消行 + 右上角快捷开关
-->
<view class="game-page {{uiThemeClass}} {{premiumClass}}" style="{{pageStyle}}" catchtouchmove="onDockTouchMove" catchtouchend="onDockTouchEnd">

  <!-- v1.60.46：与 web index.html .header--title-only 一致——文字 LOGO 优先 -->
  <view class="header header--title-only">
    <text class="app-wordmark">Open Block</text>
  </view>

  <view class="score-theme-row">
    <!-- v1.60.46：能力（Lv.N + 称号）列；progression 共用 web localStorage key -->
    <view class="stat-box header-level">
      <text class="stat-label">{{text.ability}}</text>
      <view class="header-level-val">
        <text class="progression-level">Lv.{{level}}</text>
        <text class="progression-title">{{levelTitle}}</text>
      </view>
      <text wx:if="{{streakVisible}}" class="stat-subline progression-streak">{{streakText}}</text>
      <view wx:if="{{!streakVisible}}" class="stat-subline stat-subline--spacer"></view>
    </view>
    <view class="stat-box">
      <text class="stat-label">{{text.score}}</text>
      <text class="stat-value stat-value--accent score-burst {{scoreBurstClass}}">{{score}}</text>
      <view class="stat-subline stat-subline--spacer"></view>
    </view>
    <view class="stat-box stat-box--best">
      <text class="stat-label">{{text.best}}</text>
      <text class="stat-value stat-value--accent">{{bestScore}}</text>
      <text wx:if="{{bestGapVisible}}" class="stat-subline best-gap">{{bestGapText}}</text>
      <view wx:if="{{!bestGapVisible}}" class="stat-subline stat-subline--spacer"></view>
    </view>
    <view class="stat-box">
      <text class="stat-label">{{text.steps}}</text>
      <text class="stat-value">{{steps}}</text>
      <view class="stat-subline stat-subline--spacer"></view>
    </view>
    <view class="stat-box">
      <text class="stat-label">{{text.clears}}</text>
      <text class="stat-value">{{totalClears}}</text>
      <view class="stat-subline stat-subline--spacer"></view>
    </view>
    <view class="fx-toolbar">
      <view
        class="fx-toggle fx-toggle--appearance {{appearanceClass}}"
        catchtap="onCycleAppearanceMode"
        aria-label="{{appearanceLabel}}"
      >
        <text class="fx-toggle-icon">{{appearanceIcon}}</text>
      </view>
      <view
        class="fx-toggle fx-toggle--quality"
        catchtap="onCycleQuality"
        aria-label="{{qualityLabel}}"
      >
        <text class="fx-toggle-icon">{{qualityIcon}}</text>
      </view>
      <view
        class="fx-toggle {{audioOn ? 'fx-toggle--on' : 'fx-toggle--off'}}"
        catchtap="onToggleAudio"
        aria-label="{{audioOn ? text.audioOn : text.audioOff}}"
      >
        <text class="fx-toggle-icon">{{audioOn ? '🔊' : '🔇'}}</text>
      </view>
    </view>
  </view>

  <!-- 棋盘 Canvas -->
  <view class="grid-wrapper" style="{{gridWrapperStyle}}">
    <canvas
      type="2d"
      id="game-canvas"
      class="game-canvas"
      style="width: {{canvasW}}px; height: {{canvasH}}px;"
      bindtouchstart="onGridTouchStart"
      bindtouchmove="onGridTouchMove"
      bindtouchend="onGridTouchEnd"
    />
  </view>

  <view wx:if="{{floatScoreVisible}}" class="float-score {{floatScoreClass}}">
    {{floatScoreText}}
  </view>

  <!-- 候选块（dock） -->
  <view class="dock" style="{{dockStyle}}">
    <view
      wx:for="{{dock}}"
      wx:key="index"
      class="{{item.className}}"
      style="{{item.slotStyle}}"
      data-idx="{{index}}"
      catchtouchstart="onDockTouchStart"
      catchtouchmove="onDockTouchMove"
      catchtouchend="onDockTouchEnd"
    >
      <canvas
        wx:if="{{!item.placed}}"
        type="2d"
        id="dock-canvas-{{index}}"
        class="dock-canvas"
        style="{{item.slotStyle}}"
      />
    </view>
  </view>

  <canvas
    wx:if="{{dragPreviewVisible}}"
    type="2d"
    id="drag-preview-canvas"
    class="drag-preview-canvas"
    style="{{dragPreviewStyle}}"
  />

  <!-- 游戏结束遮罩 -->
  <view wx:if="{{gameOver}}" class="game-over-overlay" bindtap="onRestart">
    <view class="game-over-card {{isNewBest ? 'game-over-card--new-best' : ''}}">
      <!-- v1.60.47：破 PB 时顶部 🏆 + "新纪录" 副标题；常规结束沿用 game-over-title -->
      <block wx:if="{{isNewBest}}">
        <text class="game-over-trophy">🏆</text>
        <text class="game-over-title game-over-title--new-best">{{text.newRecord}}</text>
      </block>
      <text wx:else class="game-over-title">{{text.gameOver}}</text>
      <text class="game-over-score">{{scoreText}}</text>
      <text class="game-over-clears">{{clearsText}}</text>
      <!-- v1.60.47：iOS 微信小程序 <view> 直接包含文本时偶发渲染丢失（line-height
        坍缩 + color 继承异常），改用 <button> 自带的"原生按钮"渲染保证文字始终可见。
        size="mini" + plain="false"，外观由 wxss 完全接管（保持原绿色胶囊样式）。 -->
      <button class="game-over-btn" type="primary" size="mini" hover-class="game-over-btn--hover" catchtap="onRestart">
        <text class="game-over-btn-text">{{text.restart}}</text>
      </button>
    </view>
  </view>

  <!-- 新手村引导 overlay -->
  <view wx:if="{{nvVisible}}" class="nv-overlay {{nvClosing ? 'nv-overlay--closing' : 'nv-overlay--visible'}}">
    <view class="nv-topbar">
      <view class="nv-brand">
        <text class="nv-spark">🏕️</text>
        <text>新手村</text>
      </view>
      <button class="nv-skip" size="mini" plain="true" catchtap="onNvSkip">跳过引导</button>
    </view>
    <view class="nv-progress">
      <view
        wx:for="{{nvDots}}"
        wx:key="index"
        class="nv-dot {{item.active ? 'nv-dot--active' : ''}} {{item.done ? 'nv-dot--done' : ''}}"
      />
    </view>
    <view wx:if="{{!nvStageHidden && !nvGraduateVisible}}" class="nv-coach">
      <text class="nv-coach__icon">{{nvCoachIcon}}</text>
      <view class="nv-coach__text">
        <text class="nv-coach__title">{{nvCoachTitle}}</text>
        <rich-text class="nv-coach__body" nodes="{{nvCoachBodyHtml}}" />
      </view>
    </view>
    <view wx:if="{{!nvStageHidden && !nvGraduateVisible}}" class="nv-stage">
      <view class="nv-hud">
        <text class="nv-score">{{nvScoreText}}</text>
        <text wx:if="{{nvComboVisible}}" class="nv-combo nv-combo--on">{{nvComboText}}</text>
      </view>
      <view class="nv-board-wrap {{nvShake ? 'nv-board-wrap--shake' : ''}}">
        <canvas
          type="2d"
          id="nv-board-canvas"
          class="nv-board-canvas"
          style="width: {{nvCanvasW}}px; height: {{nvCanvasH}}px;"
          bindtouchstart="onNvTouchStart"
          bindtouchmove="onNvTouchMove"
          bindtouchend="onNvTouchEnd"
        />
      </view>
    </view>
    <view wx:if="{{nvRevealVisible && !nvGraduateVisible}}" class="nv-reveal nv-reveal--visible">
      <text class="nv-reveal__title">{{nvRevealTitle}}</text>
      <text class="nv-reveal__body">{{nvRevealBody}}</text>
      <text class="nv-reveal__calc">{{nvRevealCalc}}</text>
    </view>
    <view wx:if="{{nvGraduateVisible}}" class="nv-graduate">
      <text class="nv-graduate__emoji">🎉</text>
      <text class="nv-graduate__title">出师啦！</text>
      <text class="nv-graduate__body">你已掌握单消 / 多消 / 同花 / 连击 / 清屏，训练赛累计得分 {{nvGraduateScore}}。真实对局采用同样的计分规则，去冲击最高分吧！</text>
      <button class="nv-cta" type="primary" size="mini" catchtap="onNvCta">开始游戏</button>
    </view>
  </view>

</view>
