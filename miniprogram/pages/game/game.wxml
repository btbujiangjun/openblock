<!--
  Open Block 微信小程序 — 游戏页面
  Canvas 2D 绘制棋盘 + touch 事件驱动拖拽放置
  顶栏与 web score-theme-row 对齐：四栏三行栅格（得分 / 步数 / 消行 / 最佳）
-->
<view class="game-page">

  <view class="score-theme-row">
    <view class="stat-box">
      <text class="stat-label">{{text.score}}</text>
      <text class="stat-value stat-value--accent">{{score}}</text>
      <view class="stat-subline stat-subline--spacer" aria-hidden="true"></view>
    </view>
    <view class="stat-box">
      <text class="stat-label">{{text.steps}}</text>
      <text class="stat-value">{{steps}}</text>
      <view class="stat-subline stat-subline--spacer" aria-hidden="true"></view>
    </view>
    <view class="stat-box">
      <text class="stat-label">{{text.clears}}</text>
      <text class="stat-value">{{totalClears}}</text>
      <view class="stat-subline stat-subline--spacer" aria-hidden="true"></view>
    </view>
    <view class="stat-box stat-box--best">
      <text class="stat-label">{{text.best}}</text>
      <text class="stat-value stat-value--accent">{{bestScore}}</text>
      <text wx:if="{{bestGapVisible}}" class="stat-subline best-gap">{{bestGapText}}</text>
      <view wx:else class="stat-subline stat-subline--spacer" aria-hidden="true"></view>
    </view>
  </view>

  <!-- 棋盘 Canvas -->
  <view class="grid-wrapper">
    <canvas
      type="2d"
      id="game-canvas"
      class="game-canvas"
      style="width: {{canvasW}}px; height: {{canvasH}}px;"
      bindtouchstart="onGridTouchStart"
      bindtouchmove="onGridTouchMove"
      bindtouchend="onGridTouchEnd"
    />
  </view>

  <view wx:if="{{floatScoreVisible}}" class="float-score {{floatScoreClass}}">
    {{floatScoreText}}
  </view>

  <!-- 候选块（dock） -->
  <view class="dock">
    <view
      wx:for="{{dock}}"
      wx:key="index"
      class="dock-slot {{item.placed ? 'dock-slot--placed' : ''}} {{dragIdx === index ? 'dock-slot--dragging' : ''}}"
      data-idx="{{index}}"
      bindtouchstart="onDockTouchStart"
      bindtouchmove="onDockTouchMove"
      bindtouchend="onDockTouchEnd"
    >
      <canvas
        wx:if="{{!item.placed}}"
        type="2d"
        id="dock-canvas-{{index}}"
        class="dock-canvas"
        style="width: {{dockSlotSize}}px; height: {{dockSlotSize}}px;"
      />
      <view wx:else class="dock-placed-mark">✓</view>
    </view>
  </view>

  <!-- 游戏结束遮罩 -->
  <view wx:if="{{gameOver}}" class="game-over-overlay" bindtap="onRestart">
    <view class="game-over-card">
      <text class="game-over-title">{{text.gameOver}}</text>
      <text class="game-over-score">{{scoreText}}</text>
      <text class="game-over-clears">{{clearsText}}</text>
      <view class="game-over-btn">{{text.restart}}</view>
    </view>
  </view>

</view>
