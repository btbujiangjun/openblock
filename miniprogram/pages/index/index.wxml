<!--
  Open Block 微信小程序 — 主菜单
-->
<view class="menu-page">
  <view class="logo-area">
    <text class="logo-title">Open</text>
    <text class="logo-star">✦</text>
    <text class="logo-title">Block</text>
  </view>
  <text class="logo-subtitle">方块消除</text>

  <view class="menu-actions">
    <view class="menu-config">
      <view class="config-row">
        <text class="config-label">皮肤</text>
        <picker mode="selector" range="{{skins}}" range-key="name" value="{{skinIndex}}" bindchange="onSkinChange">
          <view class="config-picker">{{selectedSkinName}}</view>
        </picker>
      </view>
      <view class="config-row">
        <text class="config-label">关卡</text>
        <picker mode="selector" range="{{levels}}" range-key="name" value="{{levelIndex}}" bindchange="onLevelChange">
          <view class="config-picker">{{selectedLevelName}}</view>
        </picker>
      </view>
    </view>

    <view class="menu-btn menu-btn--primary" bindtap="onStartNormal">
      <text class="menu-btn-text">开始游戏</text>
      <text class="menu-btn-sub">Normal</text>
    </view>
    <view class="menu-btn" bindtap="onStartEasy">
      <text class="menu-btn-text">简单模式</text>
      <text class="menu-btn-sub">Easy</text>
    </view>
    <view class="menu-btn" bindtap="onStartHard">
      <text class="menu-btn-text">挑战模式</text>
      <text class="menu-btn-sub">Hard</text>
    </view>
    <view class="menu-btn menu-btn--level" bindtap="onStartLevel">
      <text class="menu-btn-text">关卡模式</text>
      <text class="menu-btn-sub">{{selectedLevelId}}</text>
    </view>
  </view>

  <view class="menu-footer">
    <text class="footer-text">Open Source Block Blast</text>
  </view>
</view>
