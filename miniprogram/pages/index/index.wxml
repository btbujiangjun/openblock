<!--
  Open Block 微信小程序 — 主菜单
-->
<view class="menu-page">
  <view class="logo-area">
    <text class="logo-title">Open</text>
    <text class="logo-star">✦</text>
    <text class="logo-title">Block</text>
  </view>
  <text class="logo-subtitle">{{text.subtitle}}</text>

  <view class="menu-actions">
    <view class="menu-config">
      <view class="config-row">
        <text class="config-label">{{text.language}}</text>
        <picker mode="selector" range="{{languages}}" range-key="name" value="{{languageIndex}}" bindchange="onLanguageChange">
          <view class="config-picker">{{selectedLanguageName}}</view>
        </picker>
      </view>
      <view class="config-row">
        <text class="config-label">{{text.skin}}</text>
        <picker mode="selector" range="{{skins}}" range-key="name" value="{{skinIndex}}" bindchange="onSkinChange">
          <view class="config-picker">{{selectedSkinName}}</view>
        </picker>
      </view>
      <view class="config-row">
        <text class="config-label">{{text.difficulty}}</text>
        <picker mode="selector" range="{{difficulties}}" range-key="name" value="{{difficultyIndex}}" bindchange="onDifficultyChange">
          <view class="config-picker">{{selectedDifficultyName}}</view>
        </picker>
      </view>
    </view>

    <view class="menu-btn menu-btn--primary" bindtap="onStartGame">
      <text class="menu-btn-text">{{text.startGame}}</text>
      <text class="menu-btn-sub">{{selectedDifficultyName}}</text>
    </view>
  </view>

  <view class="menu-footer">
    <text class="footer-text">{{text.footer}}</text>
  </view>
</view>
