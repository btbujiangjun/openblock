{
  "name": "openblock",
  "version": "1.0.0",
  "description": "Block Blast — 网页方块消除游戏，含本地 IndexedDB 与可选 Flask 分析后端",
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-vite.mjs",
    "dev": "vite",
    "prebuild": "node scripts/ensure-vite.mjs",
    "build": "vite build",
    "prepreview": "node scripts/ensure-vite.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint web/src tests",
    "server": "python3 server.py",
    "server:rl": "env RL_CHECKPOINT_SAVE=rl_checkpoints/bb_policy.pt RL_SAVE_EVERY=10 RL_DEVICE=auto python3 server.py"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18"
  }
}
