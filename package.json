{
  "name": "openblock",
  "version": "1.0.0",
  "description": "Open Block — 网页方块益智游戏，经 Flask 将会话与统计持久化到 SQLite",
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-vite.mjs",
    "dev": "vite",
    "dev:3000": "npm run predev && env VITE_PORT=3000 vite",
    "dev:80": "npm run predev && env VITE_PORT=80 vite",
    "dev:sudo": "npm run predev && sudo -E env PATH=\"$PATH\" VITE_PORT=80 node node_modules/vite/bin/vite.js",
    "prebuild": "node scripts/ensure-vite.mjs && node scripts/sync-spawn-bundle.mjs && node scripts/sync-app-icon.mjs",
    "sync:app-icon": "node scripts/sync-app-icon.mjs",
    "sync:cocos-app-icon": "python3 scripts/sync-cocos-app-icon.py",
    "sync:cocos-resources": "node scripts/sync-cocos-resources.mjs",
    "build": "vite build",
    "prepreview": "node scripts/ensure-vite.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "perf:bench": "vitest bench --run tests/perf.bench.js",
    "perf:bench:cli": "node scripts/perf-bench-cli.mjs",
    "perf:baseline": "node scripts/perf-bench-cli.mjs --json --out tests/perf-baseline.json",
    "perf:check": "node scripts/perf-check.mjs",
    "perf:check:report": "node scripts/perf-check.mjs --report tests/perf-report.md",
    "perf:dfs-stats": "node scripts/perf-dfs-stats.mjs",
    "scan:dead-code": "node scripts/scan-unused-exports.mjs --strict --baseline docs/engineering/dead-code-baseline.json",
    "scan:dead-code:write-baseline": "node scripts/scan-unused-exports.mjs --strict --write-baseline docs/engineering/dead-code-baseline.json",
    "benchmark": "node scripts/benchmark-suite.mjs",
    "benchmark:quick": "node scripts/benchmark-suite.mjs --skip-perf",
    "benchmark:trend": "node scripts/benchmark-suite.mjs --skip-perf --trend-baseline docs/engineering/benchmark-trend-baseline.json",
    "perf:mono-flush": "node scripts/perf-mono-flush-bench.mjs",
    "benchmark:write-trend": "node scripts/benchmark-suite.mjs --skip-perf --write-trend docs/engineering/benchmark-trend-baseline.json",
    "perf:check:gpu": "node scripts/perf-check-gpu.mjs",
    "lint": "eslint web/src tests",
    "lint:strict": "eslint web/src tests --max-warnings 0",
    "lint:workflows": "node scripts/lint-workflows.mjs",
    "lint:dashboards": "node scripts/lint-dashboards.mjs",
    "check:dead-config": "node scripts/check-dead-config-keys.mjs",
    "gen:dsl-docs": "node scripts/gen-dsl-rules-doc.mjs",
    "check:dsl-docs": "node scripts/gen-dsl-rules-doc.mjs --check",
    "preflight": "npm run lint:strict && npm run lint:workflows && npm run lint:dashboards && npm run check:dead-config && npm run check:dsl-docs && npm run verify:cocos-core && npm test",
    "audit:artifacts": "node scripts/audit-artifacts.mjs",
    "sync:core": "bash scripts/sync-core.sh",
    "sync:cocos-core": "node scripts/sync-cocos-core.mjs && node scripts/sync-cocos-engine.mjs",
    "verify:cocos-core": "node scripts/sync-cocos-core.mjs --verify && node scripts/sync-cocos-engine.mjs --verify && node scripts/sync-cocos-resources.mjs --verify",
    "typecheck:cocos": "cd cocos && node_modules/.bin/tsc -p tsconfig.verify.json",
    "build:cocos": "bash scripts/build-cocos.sh",
    "build:cocos:web": "bash scripts/build-cocos.sh web-mobile",
    "build:cocos:wechat": "bash scripts/build-cocos.sh wechatgame",
    "sync:spawn-bundle": "node scripts/sync-spawn-bundle.mjs",
    "verify:spawn-bundle": "node scripts/sync-spawn-bundle.mjs --verify",
    "setup:android": "bash scripts/android-env.sh --check",
    "setup:android:install": "bash scripts/android-env.sh --install-studio",
    "mobile:sync": "cd mobile && ../node_modules/.bin/cap sync",
    "mobile:copy": "cd mobile && ../node_modules/.bin/cap copy",
    "mobile:build": "npm run build && npm run mobile:sync",
    "mobile:android": "node scripts/open-android-studio.mjs mobile/android",
    "cocos:android": "bash cocos/scripts/build-android.sh",
    "cocos:android:open": "bash cocos/scripts/build-android.sh --open",
    "cocos:android:apk": "bash cocos/scripts/build-android.sh --apk",
    "mobile:ios": "cd mobile && ../node_modules/.bin/cap open ios",
    "mobile:apk:debug": "node scripts/android-apk.mjs debug",
    "mobile:apk:release": "node scripts/android-apk.mjs release",
    "android:debug": "bash scripts/android-debug.sh",
    "android:debug:build": "bash scripts/android-debug.sh build",
    "android:debug:assemble": "bash scripts/android-debug.sh assemble",
    "android:logcat": "bash scripts/android-debug.sh logcat",
    "restart": "bash scripts/restart-openblock.sh",
    "restart:full": "bash scripts/restart-openblock.sh --full",
    "stop": "bash scripts/stop-openblock.sh",
    "server": "python3 server.py",
    "server:rl": "env RL_CHECKPOINT_SAVE=rl_checkpoints/bb_policy.pt RL_TRAINING_LOG=rl_checkpoints/training.jsonl RL_SAVE_EVERY=500 RL_DEVICE=auto RL_AUTOLOAD=1 RL_LR=1e-4 RL_GAMMA=0.99 RL_VALUE_COEF=1.0 RL_VALUE_HUBER_BETA=1.0 RL_ENTROPY_COEF=0.025 RL_ENTROPY_COEF_MIN=0.008 RL_ENTROPY_DECAY_EPISODES=60000 RL_RETURN_SCALE=1.0 RL_ADV_NORM=1 RL_ADV_MIN_STD=1e-4 RL_GRAD_CLIP=0.3 RL_PPO_EPOCHS_ONLINE=1 RL_CURRICULUM=1 RL_WIDTH=128 python3 server.py",
    "profile:audit": "node scripts/audit-profile.mjs",
    "profile:auto-audit": "node scripts/auto-audit-all.mjs",
    "spawn:realtime-tune": "node scripts/tune-realtime-state.mjs",
    "spawn:difficulty-agg": "node scripts/aggregate-step-difficulty.mjs",
    "spawn:exact-match": "node scripts/audit-exact-match.mjs",
    "rl:eval": "python3 -m rl_pytorch.eval_cli",
    "spawn:gate": "python3 -m rl_pytorch.spawn_model.test_drift && python3 -m rl_pytorch.spawn_model.test_v3",
    "spawn:drift-check": "python3 -m rl_pytorch.spawn_model.drift_check",
    "spawn:theta-readiness": "python3 -m rl_pytorch.spawn_model.theta_readiness",
    "spawn:fact-eval": "python3 -m rl_pytorch.spawn_tuning_v2.fact_eval",
    "release:check:web": "npm run lint && npm test && npm run build",
    "release:check:miniprogram": "node --check miniprogram/core/adaptiveSpawn.js && node --check miniprogram/core/bot/blockSpawn.js && node --check miniprogram/utils/gameController.js && npx vitest run tests/miniprogramCore.test.js",
    "release:check:mobile": "npm run build && npm run mobile:sync",
    "release:check": "npm run release:check:web && npm run release:check:miniprogram && npm run release:check:mobile"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@eslint/js": "^9.15.0",
    "@vitejs/plugin-legacy": "^5.4.3",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.15.0",
    "fast-check": "^3.23.2",
    "globals": "^17.6.0",
    "jsdom": "^24.1.3",
    "terser": "^5.48.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18"
  }
}
