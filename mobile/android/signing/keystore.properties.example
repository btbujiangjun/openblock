# 复制为 keystore.properties 并填写真实值（勿提交 keystore.properties / *.keystore）
# cp mobile/android/signing/keystore.properties.example mobile/android/signing/keystore.properties
#
# 上架 Google Play / 应用市场请使用独立生产密钥，勿与示例密码混用。

storeFile=openblock-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=openblock
keyPassword=YOUR_KEY_PASSWORD
