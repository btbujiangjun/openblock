<?xml version="1.0" encoding="utf-8"?>
<!--
    自定义 Activity 主题。最大用途：替换 Cocos 默认的纯黑 windowBackground，
    在「桌面图标点击 → JS 首帧渲染完成」之间的 ~1.7s 空窗期，让用户看到
    品牌色背景 + app 图标，而不是死黑屏。

    实测启动时序（华为 Mate30 EMUI 10）：
      0ms     桌面点击
      245ms   ActivityTaskManager: Displayed（系统进入 app，黑屏开始）
      ~1450ms Cocos GL/JS bundle 加载完，开始渲染首帧
      ~1900ms 首帧画面出现
    所以无论引擎怎么优化，这段窗口至少 ~1.5s，必须靠 windowBackground 兜底。

    注意：parent 必须用 Holo/Material 系列（非 NoTitleBar.Fullscreen），后者会忽略
    windowBackground 资源 → 仍然黑屏。Material.Light.NoActionBar.Fullscreen 配合
    statusBarColor 控制即可达到「全屏 + 自定义启动图」。
-->
<resources>
    <style name="AppTheme.Launcher" parent="@android:style/Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowBackground">@drawable/launch_screen</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
